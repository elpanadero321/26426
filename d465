    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy.integrate import solve_ivp\n",
        "\n",
        "\n",
        "def rhs_dvch_n(N, y, n, beta):\n",
        "    rho_m, rho_l, rho_r = y\n",
        "\n",
        "    rho_m = max(rho_m, 1e-15)\n",
        "    rho_l = max(rho_l, 0.0)\n",
        "    rho_r = max(rho_r, 0.0)\n",
        "\n",
        "    e2 = max(rho_m + rho_l + rho_r, 1e-20)\n",
        "    e = np.sqrt(e2)\n",
        "\n",
        "    qtilde = -e * rho_l / (1.0 + n * rho_l / rho_m) * (\n",
        "        n - (beta / (1.0 + beta * e2)) * ((4.0 * rho_r + 3.0 * rho_m) / 3.0)\n",
        "    )\n",
        "\n",
        "    drho_m_dN = -3.0 * rho_m - 3.0 * qtilde / e\n",
        "    drho_l_dN = 3.0 * qtilde / e\n",
        "    drho_r_dN = -4.0 * rho_r\n",
        "\n",
        "    return [drho_m_dN, drho_l_dN, drho_r_dN]\n",
        "\n",
        "\n",
        "def integrate_branch(N_span, y0, n, beta, npts):\n",
        "    N_eval = np.linspace(N_span[0], N_span[1], npts)\n",
        "    sol = solve_ivp(\n",
        "        fun=lambda N, y: rhs_dvch_n(N, y, n=n, beta=beta),\n",
        "        t_span=N_span,\n",
        "        y0=y0,\n",
        "        t_eval=N_eval,\n",
        "        rtol=1e-9,\n",
        "        atol=1e-12,\n",
        "        method=\"RK45\",\n",
        "    )\n",
        "\n",
        "    if not sol.success:\n",
        "        raise RuntimeError(sol.message)\n",
        "\n",
        "    return sol.t, sol.y\n",
        "\n",
        "\n",
        "def solve_dvch_future(\n",
        "    H0=73.0,\n",
        "    Omega_m0=0.30,\n",
        "    Omega_r0=9e-5,\n",
        "    n=0.20,\n",
        "    beta=1e-4,\n",
        "    N_past=-2.5,\n",
        "    N_future=3.0,\n",
        "    npts=5000,\n",
        "):\n",
        "    Omega_l0 = 1.0 - Omega_m0 - Omega_r0\n",
        "    y0 = [Omega_m0, Omega_l0, Omega_r0]\n",
        "\n",
        "    npts_back = max(2, npts // 2)\n",
        "    npts_forw = max(2, npts - npts_back + 1)\n",
        "\n",
        "    N_back, y_back = integrate_branch((0.0, N_past), y0, n, beta, npts_back)\n",
        "    N_forw, y_forw = integrate_branch((0.0, N_future), y0, n, beta, npts_forw)\n",
        "\n",
        "    N_all = np.concatenate([N_back[::-1], N_forw[1:]])\n",
        "    y_all = np.concatenate([y_back[:, ::-1], y_forw[:, 1:]], axis=1)\n",
        "\n",
        "    Omega_m, Omega_l, Omega_r = y_all\n",
        "    E2 = np.maximum(Omega_m + Omega_l + Omega_r, 1e-20)\n",
        "    E = np.sqrt(E2)\n",
        "\n",
        "    a = np.exp(N_all)\n",
        "    z = 1.0 / a - 1.0\n",
        "    H = H0 * E\n",
        "    q = -1.0 - np.gradient(np.log(E), N_all)\n",
        "\n",
        "    return {\n",
        "        \"N\": N_all,\n",
        "        \"a\": a,\n",
        "        \"z\": z,\n",
        "        \"H\": H,\n",
        "        \"E\": E,\n",
        "        \"q\": q,\n",
        "        \"Omega_m\": Omega_m,\n",
        "        \"Omega_l\": Omega_l,\n",
        "        \"Omega_r\": Omega_r,\n",
        "    }\n",
        "\n",
        "\n",
        "def solve_lcdm_future(\n",
        "    H0=73.0,\n",
        "    Omega_m0=0.30,\n",
        "    Omega_r0=9e-5,\n",
        "    N_past=-2.5,\n",
        "    N_future=3.0,\n",
        "    npts=5000,\n",
        "):\n",
        "    N = np.linspace(N_past, N_future, npts)\n",
        "    a = np.exp(N)\n",
        "    z = 1.0 / a - 1.0\n",
        "\n",
        "    Omega_l0 = 1.0 - Omega_m0 - Omega_r0\n",
        "    E2 = Omega_m0 * a**(-3) + Omega_r0 * a**(-4) + Omega_l0\n",
        "    E = np.sqrt(E2)\n",
        "    H = H0 * E\n",
        "    q = -1.0 - np.gradient(np.log(E), N)\n",
        "\n",
        "    Omega_m = (Omega_m0 * a**(-3)) / E2\n",
        "    Omega_r = (Omega_r0 * a**(-4)) / E2\n",
        "    Omega_l = Omega_l0 / E2\n",
        "\n",
        "    return {\n",
        "        \"N\": N,\n",
        "        \"a\": a,\n",
        "        \"z\": z,\n",
        "        \"H\": H,\n",
        "        \"E\": E,\n",
        "        \"q\": q,\n",
        "        \"Omega_m\": Omega_m,\n",
        "        \"Omega_l\": Omega_l,\n",
        "        \"Omega_r\": Omega_r,\n",
        "    }\n",
        "\n",
        "\n",
        "def make_plots(dvch, lcdm):\n",
        "    plt.style.use(\"seaborn-v0_8-whitegrid\")\n",
        "\n",
        "    fig, ax = plt.subplots(1, 3, figsize=(16, 5))\n",
        "    fig.suptitle(\"DVCH vs ΛCDM (background)\", fontsize=16)\n",
        "\n",
        "    ax[0].plot(dvch[\"a\"], dvch[\"H\"], lw=2.5, label=\"DVCH\")\n",
        "    ax[0].plot(lcdm[\"a\"], lcdm[\"H\"], \"--\", lw=2.2, label=\"ΛCDM\")\n",
        "    ax[0].axvline(1.0, color=\"k\", ls=\":\", lw=1.2)\n",
        "    ax[0].set_xscale(\"log\")\n",
        "    ax[0].set_xlabel(\"a\")\n",
        "    ax[0].set_ylabel(r\"$H(a)$ [km s$^{-1}$ Mpc$^{-1}$]\")\n",
        "    ax[0].set_title(\"Expansion rate\")\n",
        "    ax[0].legend()\n",
        "\n",
        "    ax[1].plot(dvch[\"a\"], dvch[\"q\"], lw=2.5, label=\"DVCH\")\n",
        "    ax[1].plot(lcdm[\"a\"], lcdm[\"q\"], \"--\", lw=2.2, label=\"ΛCDM\")\n",
        "    ax[1].axvline(1.0, color=\"k\", ls=\":\", lw=1.2)\n",
        "    ax[1].axhline(0.0, color=\"k\", ls=\"--\", lw=1.0)\n",
        "    ax[1].set_xscale(\"log\")\n",
        "    ax[1].set_xlabel(\"a\")\n",
        "    ax[1].set_ylabel(\"q(a)\")\n",
        "    ax[1].set_title(\"Acceleration diagnostic\")\n",
        "    ax[1].legend()\n",
        "\n",
        "    ax[2].plot(dvch[\"a\"], dvch[\"Omega_m\"], lw=2.5, label=r\"$\\Omega_m$\")\n",
        "    ax[2].plot(dvch[\"a\"], dvch[\"Omega_l\"], lw=2.5, label=r\"$\\Omega_\\Lambda$\")\n",
        "    ax[2].plot(dvch[\"a\"], dvch[\"Omega_r\"], lw=2.5, label=r\"$\\Omega_r$\")\n",
        "    ax[2].axvline(1.0, color=\"k\", ls=\":\", lw=1.2)\n",
        "    ax[2].set_xscale(\"log\")\n",
        "    ax[2].set_xlabel(\"a\")\n",
        "    ax[2].set_ylabel(r\"$\\Omega_i$\")\n",
        "    ax[2].set_title(\"Component evolution (DVCH)\")\n",
        "    ax[2].legend()\n",
        "\n",
        "    plt.tight_layout()\n",
        "    plt.savefig(\"dvch_vs_lcdm_background.png\", dpi=300, bbox_inches=\"tight\")\n",
        "    plt.show()\n",
        "\n",
        "\n",
        "def main():\n",
        "    params = {\n",
        "        \"H0\": 73.0,\n",
        "        \"Omega_m0\": 0.30,\n",
        "        \"Omega_r0\": 9e-5,\n",
        "        \"n\": 0.20,\n",
        "        \"beta\": 1e-4,\n",
        "        \"N_past\": -2.5,\n",
        "        \"N_future\": 3.0,\n",
        "        \"npts\": 5000,\n",
        "    }\n",
        "\n",
        "    dvch = solve_dvch_future(**params)\n",
        "    lcdm = solve_lcdm_future(\n",
        "        H0=params[\"H0\"],\n",
        "        Omega_m0=params[\"Omega_m0\"],\n",
        "        Omega_r0=params[\"Omega_r0\"],\n",
        "        N_past=params[\"N_past\"],\n",
        "        N_future=params[\"N_future\"],\n",
        "        npts=params[\"npts\"],\n",
        "    )\n",
        "\n",
        "    print(f\"a hoy = {np.interp(0.0, dvch['N'], dvch['a']):.6f}\")\n",
        "    print(f\"H hoy = {np.interp(1.0, dvch['a'], dvch['H']):.6f}\")\n",
        "    print(f\"q hoy = {np.interp(1.0, dvch['a'], dvch['q']):.6f}\")\n",
        "    print(f\"Omega_m futuro lejano = {dvch['Omega_m'][-1]:.6e}\")\n",
        "    print(f\"Omega_L futuro lejano = {dvch['Omega_l'][-1]:.6e}\")\n",
        "\n",
        "    make_plots(dvch, lcdm)\n",
        "\n",
        "\n",
        "if __name__ == \"__main__\":\n",
        "    main()"
      ],
